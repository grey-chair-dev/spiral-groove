# Neon Auth environment variables for Next.js
NEXT_PUBLIC_STACK_PROJECT_ID=****************************
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=****************************************
STACK_SECRET_SERVER_KEY=***********************

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN="24h"

# Feature Flags
ENABLE_SQUARE_INTEGRATION="false"
ENABLE_EMAIL_SERVICE="false"
ENABLE_ANALYTICS="false"
ENABLE_SOCIAL_MEDIA="false"
ENABLE_IMAGE_CDN="false"
ENABLE_REDIS_CACHE="false"

# Square API Configuration (when ENABLE_SQUARE_INTEGRATION=true)
SQUARE_APPLICATION_ID="your-square-application-id"
SQUARE_APPLICATION_SECRET="your-square-application-secret"
SQUARE_ACCESS_TOKEN="your-square-access-token"
SQUARE_ENVIRONMENT="sandbox" # or "production"
SQUARE_WEBHOOK_SIGNATURE_KEY="your-square-webhook-signature-key"

# Email Service Configuration (when ENABLE_EMAIL_SERVICE=true)
EMAIL_SERVICE="resend" # or "nodemailer"
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASSWORD="your-resend-api-key"
SMTP_FROM="noreply@spiralgroove.com"

# Resend API (when EMAIL_SERVICE=resend)
RESEND_API_KEY="your-resend-api-key"

# Analytics Configuration (when ENABLE_ANALYTICS=true)
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
MIXPANEL_TOKEN="your-mixpanel-token"

# Social Media APIs (when ENABLE_SOCIAL_MEDIA=true)
INSTAGRAM_ACCESS_TOKEN="your-instagram-access-token"
TIKTOK_ACCESS_TOKEN="your-tiktok-access-token"

# Image CDN Configuration (when ENABLE_IMAGE_CDN=true)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Redis Cache Configuration (when ENABLE_REDIS_CACHE=true)
REDIS_URL="redis://localhost:6379"
KV_REST_API_URL="your-vercel-kv-url"
KV_REST_API_TOKEN="your-vercel-kv-token"
KV_REST_API_READ_ONLY_TOKEN="your-vercel-kv-readonly-token"

# File Upload Configuration
MAX_FILE_SIZE="10485760" # 10MB in bytes
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,image/avif"

# Rate Limiting Configuration
RATE_LIMIT_MAX="100" # requests per window
RATE_LIMIT_WINDOW="60000" # 1 minute in milliseconds

# Application Configuration
NODE_ENV="development"
PORT="3000"
HOSTNAME="localhost"

# Security Configuration
BCRYPT_ROUNDS="12"
SESSION_MAX_AGE="86400" # 24 hours in seconds

# External Service URLs
SQUARE_API_URL="https://connect.squareup.com/v2"
SQUARE_PAYMENTS_URL="https://web.squareup.com/v2/payments"

# Development Tools
ENABLE_DEBUG="true"
ENABLE_LOGGING="true"
LOG_LEVEL="info"

# Production Overrides (uncomment for production)
# NODE_ENV="production"
# NEXTAUTH_URL="https://your-domain.com"
# SQUARE_ENVIRONMENT="production"
# ENABLE_DEBUG="false"
# LOG_LEVEL="warn"
