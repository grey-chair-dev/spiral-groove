# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================
# Choose ONE auth provider and add its credentials below

# --- Neon Auth (Recommended) ---
VITE_NEON_AUTH_URL=https://auth.your-neon-app.com
VITE_STACK_PROJECT_ID=stack-project-id
VITE_STACK_PUBLISHABLE_CLIENT_KEY=pk_live_example
#
# Neon docs (legacy Stack Auth) use Next.js-style names:
#   NEXT_PUBLIC_STACK_PROJECT_ID=...
#   NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=...
# This project supports those too, but in Vite you typically prefer VITE_*.

# --- Supabase (Alternative) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Auth0 (Alternative) ---
# VITE_AUTH0_DOMAIN=your-domain.auth0.com
# VITE_AUTH0_CLIENT_ID=your-client-id

# --- Clerk (Alternative) ---
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_example

# --- Firebase (Alternative) ---
# VITE_FIREBASE_API_KEY=your-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id

# --- OAuth Providers (works with any auth service above) ---
# Set to 'false' to disable specific providers
VITE_OAUTH_GOOGLE_ENABLED=true
VITE_OAUTH_GITHUB_ENABLED=true
VITE_OAUTH_APPLE_ENABLED=false
VITE_OAUTH_MICROSOFT_ENABLED=false

# --- Email/Password Auth ---
# Set to 'false' to disable email/password login
VITE_EMAIL_PASSWORD_ENABLED=true

# ============================================
# DATA & PRODUCTS CONFIGURATION
# ============================================
#
# Neon Database Connection (REQUIRED for product data)
# Prefer SGR_* (Spiral Groove Records) variables.
SGR_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Legacy (supported for backward compatibility)
SPR_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

VITE_PRODUCTS_WS_URL=wss://adapter.your-domain.com/realtime
VITE_APP_ID=demo-local-commerce
VITE_ENABLE_MOCK_DATA=true

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_WISHLIST=true
VITE_ENABLE_ORDER_TRACKING=true
VITE_ENABLE_MAINTENANCE_PAGE=false
VITE_CHECKOUT_MODE=both
# Shipping: fixed fee in USD when delivery is selected (default 10). Material & media shipping. Domestic (US) only.
# VITE_SHIPPING_FEE=10
# Free shipping when order subtotal >= this (USD). 0 = no free shipping. Backend: FREE_SHIPPING_THRESHOLD_CENTS (cents).
# VITE_FREE_SHIPPING_THRESHOLD=0

# ============================================
# MAKE.COM WEBHOOKS
# ============================================
# Events page "Book The Space" inquiry form → Make scenario webhook
MAKE_EVENTS_INQUIRY_WEBHOOK_URL=https://hook.us2.make.com/your-webhook-id

# Contact page "Contact Us" form → Make scenario webhook
MAKE_CONTACT_US_WEBHOOK_URL=https://hook.us2.make.com/your-webhook-id

# Newsletter signup form → Make scenario webhook
MAKE_NEWSLETTER_SIGNUP_WEBHOOK_URL=https://hook.us2.make.com/your-webhook-id

# ============================================
# SQUARE (SERVER)
# ============================================
# Used by:
# - /api/pay (payments)
# - /api/square/sync (catalog -> Neon sync)
# - scripts/sync-square.mjs (manual sync)
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your-square-location-id

# Optional: protect admin webhooks (used by /api/square/sync, /api/orders/update, etc.)
WEBHOOK_SECRET=your-shared-secret

# ============================================
# VERCEL FLAGS (Flags SDK + /api/flags/*)
# ============================================
# Populated automatically when you link the project and run: vercel env pull
# Required for subscription flag and Flags Explorer (/.well-known/vercel/flags).
# When `subscription` is off: weekly bulk newsletter + npm run send:weekly-newsletter skip sends;
# chatbot hides newsletter quick reply and newsletter-related answers.
# FLAGS=
# FLAGS_SECRET=
# Inspect a flag (requires Vercel CLI with `flags` subcommand): vercel flags inspect subscription

# Shipping (server): /api/pay calculates shipping. Material & media. Domestic (US) only. SHIPPING_FEE (USD) or SHIPPING_FEE_CENTS. Optional: FREE_SHIPPING_THRESHOLD_CENTS.
# SHIPPING_FEE=10
# FREE_SHIPPING_THRESHOLD_CENTS=0

# ============================================
# REVIEWS
# ============================================
# Used in the "Order Status Update" email when an order is marked COMPLETED (picked up).
#
# Choose one:
# - Google Maps: https://www.google.com/maps/place/Spiral+Groove+Records/@39.1742742,-84.2984339,17z/data=!3m2!4b1!5s0x8841aac9305a4841:0xf7aca0c9046f7901!4m6!3m5!1s0x8841aab22ada7577:0xab535c9a0a82b016!8m2!3d39.1742742!4d-84.295859!16s%2Fg%2F11dfxntdfb?entry=ttu
# - Yelp:       https://www.yelp.com/writeareview/biz/5CvwbwLxonlDI9jDx_3YcQ?return_url=%2Fbiz%2F5CvwbwLxonlDI9jDx_3YcQ&review_origin=biz-details-war-button
# - Facebook:   https://www.facebook.com/spiralgrooverecords/reviews/?id=100063558614296&sk=reviews
SGR_REVIEW_URL=https://www.facebook.com/spiralgrooverecords/reviews/?id=100063558614296&sk=reviews

# Optional secondary review destination (shown as a second button in the review email)
SGR_REVIEW_URL_SECONDARY=https://www.google.com/maps/place/Spiral+Groove+Records/@39.1742742,-84.2984339,17z/data=!3m2!4b1!5s0x8841aac9305a4841:0xf7aca0c9046f7901!4m6!3m5!1s0x8841aab22ada7577:0xab535c9a0a82b016!8m2!3d39.1742742!4d-84.295859!16s%2Fg%2F11dfxntdfb?entry=ttu

# ============================================
# MONTHLY REPORT (cron: 1st of month)
# ============================================
# Who receives the report (comma-separated)
MONTHLY_REPORT_RECIPIENTS=brendan@greychair.io
# REPORT_EMAIL=brendan@greychair.io

# Optional: From address (default projects@greychair.io)
# MONTHLY_REPORT_FROM=projects@greychair.io

# Google Analytics (GA4) for report – optional; see docs/ga4-monthly-report.md
# GA4 Property ID (numeric only; Spiral Groove Records = 516751405)
# GA4_PROPERTY_ID=516751405

# GA4 credentials: JSON string (Vercel) or local file path (dev; file is gitignored)
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GA4_SERVICE_ACCOUNT_PATH=docs/grey-chair-digital-service-account.json

# Service account JSON (full key file contents) for GA4 Data API
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...",...}

# Optional: secret for /api/monthly-report-data (used by Make.com when building report with GA4 OAuth instead of service account)
# MONTHLY_REPORT_DATA_SECRET=your-random-secret